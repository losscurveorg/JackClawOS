# JackClaw Environment Variables
# Copy to .env or set in your shell

# ─── Hub Configuration ────────────────────────────────────────────
HUB_PORT=3100
JACKCLAW_HUB_URL=http://localhost:3100

# ─── Node Configuration ───────────────────────────────────────────
NODE_PORT=19000
JACKCLAW_NODE_ID=my-node

# ─── LLM Providers ────────────────────────────────────────────────
# Set the keys for the models you want to use.
# JackClaw auto-routes to the right provider by model name.

# Anthropic — Claude (claude-sonnet-4-6, claude-opus-4, claude-haiku-3-5)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: custom base URL (e.g. for proxies)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI — GPT (gpt-4o, gpt-4o-mini, o1, o3-mini)
OPENAI_API_KEY=sk-...

# Google — Gemini (gemini-2.0-flash, gemini-1.5-pro)
GOOGLE_API_KEY=AIza...

# DeepSeek — deepseek-chat, deepseek-reasoner (very cheap!)
DEEPSEEK_API_KEY=sk-...

# Groq — Ultra-fast inference (llama-3.3-70b, mixtral)
GROQ_API_KEY=gsk_...

# Mistral — mistral-large, mistral-medium
MISTRAL_API_KEY=...

# Together AI — 200+ open models
TOGETHER_API_KEY=...

# OpenRouter — Route to any model (200+)
OPENROUTER_API_KEY=sk-or-...

# Ollama — Local models (no key needed, just run ollama serve)
# OLLAMA_BASE_URL=http://localhost:11434
