{
  "name": "jackclaw",
  "version": "0.2.0",
  "private": true,
  "bin": {
    "jackclaw": "packages/cli/dist/index.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "node tests/run-all.js",
    "dev": "concurrently \"npm run dev --workspace=packages/hub\" \"npm run dev --workspace=packages/node\"",
    "dev:hub": "npm run dev --workspace=packages/hub",
    "dev:node": "npm run dev --workspace=packages/node",
    "dev:cli": "npm run dev --workspace=packages/cli",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "publish:dry": "node scripts/publish.js",
    "publish:live": "node scripts/publish.js --live",
    "publish:beta": "node scripts/publish.js --live --tag=beta",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "MIT"
}
