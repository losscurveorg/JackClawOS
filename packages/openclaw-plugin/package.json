{
  "name": "@jackclaw/openclaw-plugin",
  "version": "0.1.0",
  "description": "JackClaw OpenClaw Plugin — team reports and node status via any OpenClaw channel",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@jackclaw/protocol": "^0.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "devDependencies": {
    "openclaw": "file:/opt/homebrew/lib/node_modules/openclaw",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "jackclaw",
    "openclaw",
    "plugin",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DevJackKong/JackClawOS.git"
  },
  "homepage": "https://github.com/DevJackKong/JackClawOS#readme",
  "bugs": {
    "url": "https://github.com/DevJackKong/JackClawOS/issues"
  }
}
