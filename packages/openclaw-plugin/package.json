{
  "name": "@jackclaw/openclaw-plugin",
  "version": "0.2.0",
  "description": "JackClaw OpenClaw Plugin — team reports and node status via any OpenClaw channel",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@jackclaw/protocol": "^0.2.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "jackclaw",
    "openclaw",
    "plugin",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DevJackKong/JackClawOS.git"
  },
  "homepage": "https://github.com/DevJackKong/JackClawOS#readme",
  "bugs": {
    "url": "https://github.com/DevJackKong/JackClawOS/issues"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
