{
  "name": "@jackclaw/sdk",
  "version": "0.1.0",
  "description": "JackClaw Plugin Development SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@jackclaw/harness": "^0.1.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "jackclaw",
    "sdk",
    "plugin",
    "agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevJackKong/JackClawOS.git"
  },
  "homepage": "https://github.com/DevJackKong/JackClawOS#readme",
  "bugs": {
    "url": "https://github.com/DevJackKong/JackClawOS/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
